{
  "schema": "autosci.benchmark_manifest.v0.1",
  "name": "AutoScientist-Bench",
  "version": "0.1",
  "created_at": "2026-05-21",
  "purpose": "Evaluate AutoScientist as a persistent scientific execution runtime with public biomedical grounding, replayable provenance, SciState Graph memory, and SciFlow Policy controller traces.",
  "public_sources": [
    {
      "name": "Open Targets Platform GraphQL API",
      "url": "https://api.platform.opentargets.org/api/v4/graphql",
      "purpose": "Target, disease, drug, tractability, and association grounding."
    },
    {
      "name": "NCBI E-utilities",
      "url": "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/",
      "purpose": "PubMed and Gene metadata grounding."
    },
    {
      "name": "Therapeutics Data Commons",
      "url": "https://tdcommons.ai/",
      "purpose": "Optional later-scale model/dataset benchmark source for therapeutic ML tasks."
    }
  ],
  "rubric": {
    "completed_run": 15,
    "nonempty_hypothesis": 10,
    "evidence_collected": 10,
    "scored_evidence": 10,
    "experiments_proposed": 10,
    "guardrails_present": 10,
    "auditable_trace": 10,
    "public_grounding": 7,
    "memory_or_replay": 7,
    "controller_advice": 6,
    "external_agent_adapter": 5
  },
  "task_templates": [
    {
      "id": "target_prioritization",
      "objective_template": "Prioritize therapeutic hypotheses for {gene_symbol} in {disease_name}; use public biomedical evidence, identify weak or failed branches, score confidence, and propose validation experiments."
    },
    {
      "id": "mechanism_safety_review",
      "objective_template": "Assess whether {gene_symbol}-linked biology is a plausible and safe intervention direction for {disease_name}; separate direct evidence, indirect mechanism, safety concerns, and missing validation."
    },
    {
      "id": "experiment_design",
      "objective_template": "Design the next experiments to test a bounded {gene_symbol} hypothesis in {disease_name}; include expected information gain, failure modes, provenance, and public evidence requirements."
    }
  ],
  "seed_cases": [
